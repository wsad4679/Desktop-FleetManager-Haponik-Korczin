<!-- (UserControl - widok) -->

<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:FleetManager.ViewModels"
             x:Class="FleetManager.Views.VehicleItemView"
             x:DataType="vm:VehicleItemViewModel">

    <Border Background="#1E293B"
            CornerRadius="10"
            Padding="12"
            Margin="5"
            BoxShadow="0 2 8 #00000040">

        <StackPanel Spacing="8">

            <TextBlock Text="{Binding Vehicle.VehicleName}"
                       FontSize="16"
                       FontWeight="Bold"
                       Foreground="White"/>

            <StackPanel Orientation="Horizontal" Spacing="5">
                <TextBlock Text="Rejestracja:"
                           Foreground="#94A3B8"/>
                <TextBlock Text="{Binding Vehicle.RegistrationNumber}"
                           Foreground="White"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="5">
                <TextBlock Text="Paliwo:"
                           Foreground="#94A3B8"/>
                <TextBlock Text="{Binding Vehicle.FuelLevel}"
                           Foreground="White"/>
                <TextBlock Text="%"
                           Foreground="White"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="5">
                <TextBlock Text="Status:"
                           Foreground="#94A3B8"/>
                <TextBlock Text="{Binding Vehicle.Status}"
                           Foreground="#38BDF8"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal"
                        Spacing="8"
                        Margin="0,10,0,0">

                <Button Content="Tankuj"
                        Background="#22C55E"
                        Foreground="White"
                        Command="{Binding RefuelCommand}"/>

                <Button Content="Trasa"
                        Background="#F59E0B"
                        Foreground="White"
                        Command="{Binding SendToRouteCommand}"/>

                <Button Content="Edytuj"
                        Background="#3B82F6"
                        Foreground="White"
                        Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).EditCommand}"
                        CommandParameter="{Binding Vehicle}"/>

                <Button Content="Usuń"
                        Background="#EF4444"
                        Foreground="White"
                        Command="{Binding RemoveCommand}"/>

            </StackPanel>

        </StackPanel>
    </Border>

</UserControl>